---
import Base from '../../layouts/Base.astro';
import PageHero from '../../components/PageHero.astro';
import { scholars } from '../../data/scholars';
---
<Base
  title="Our Scholars | Muraqabah Initiative"
  description="Meet the scholars of Muraqabah Initiative: Shaykh Zakaria Abdilaziz and Shaykh Nuh Sanders, trained at Dar al-Mustafa in Tarim, Yemen, within unbroken chains of traditional Islamic scholarship."
>
  <PageHero
    eyebrow="Our Scholars"
    title="Connected to a living tradition"
    lede="That living connection to Tarim, one of the world's great centres of sacred knowledge, is the foundation of everything Muraqabah teaches. Our students are not consuming content; they are being connected to an unbroken chain of transmission."
    crumbs={[{ name: 'Home', href: '/' }, { name: 'Scholars', href: '/scholars/' }]}
  />
  <section class="section--tight" style="padding-bottom: clamp(4rem, 8vw, 6rem);">
    <div class="container grid cols-2">
      {scholars.map((s) => (
        <article class="card" data-reveal>
          <a class="card__media" href={`/scholars/${s.slug}/`} tabindex="-1" aria-hidden="true" style="aspect-ratio: 4/3; background: var(--espresso);">
            <img src={s.portrait} alt={s.portraitAlt} width="760" height="570" loading="lazy" style="object-position: top;" />
          </a>
          <div class="card__body">
            <p class="meta">{s.role}</p>
            <h3><a href={`/scholars/${s.slug}/`} style="color:inherit; text-decoration:none;">{s.name}</a></h3>
            <p>{s.short}</p>
            <a class="text-link" href={`/scholars/${s.slug}/`}>Read full profile &rarr;</a>
          </div>
        </article>
      ))}
    </div>
  </section>
</Base>
