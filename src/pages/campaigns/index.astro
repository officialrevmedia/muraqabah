---
import Base from '../../layouts/Base.astro';
import PageHero from '../../components/PageHero.astro';
import DonateBand from '../../components/DonateBand.astro';
import { ramadan2026, qurbani2026 } from '../../data/campaigns';
const campaigns = [
  { ...ramadan2026, slug: 'ramadan-2026', image: '/images/photos/khidmah-meals.webp', alt: 'Prepared hot meals ready for delivery', badge: 'Ramadan 2026' },
  { ...qurbani2026, slug: 'qurbani-2026', image: '/images/photos/khidmah-rice-tarim.webp', alt: 'Rice support delivered in Tarim, Yemen', badge: 'Eid al-Adha 2026' }
];
---
<Base
  title="Campaigns | Muraqabah Initiative"
  description="Muraqabah Initiative khidmah campaigns: the 2026 Ramadan food campaign and Qurbani 2026 in Tarim, Yemen. Transparent, documented community service rooted in the Prophetic tradition."
>
  <PageHero
    eyebrow="Campaigns"
    title="Khidmah, delivered with care"
    lede="Our charitable campaigns are carried out with transparency and accountability, at home in Canada and through trusted networks overseas."
    crumbs={[{ name: 'Home', href: '/' }, { name: 'Campaigns', href: '/campaigns/' }]}
  />
  <section class="section--tight" style="padding-bottom: clamp(4rem, 8vw, 6rem);">
    <div class="container grid cols-2">
      {campaigns.map((c) => (
        <article class="card" data-reveal>
          <a class="card__media" href={`/campaigns/${c.slug}/`} tabindex="-1" aria-hidden="true"><img src={c.image} alt={c.alt} width="640" height="427" loading="lazy" /></a>
          <div class="card__body">
            <span class="badge badge--done">{c.badge} &middot; {c.status}</span>
            <h3><a href={`/campaigns/${c.slug}/`} style="color:inherit; text-decoration:none;">{c.title}</a></h3>
            <p class="meta" style="color: var(--rust); font-size: 1.1rem; text-transform: none; letter-spacing: 0;">{c.raised} raised</p>
            <p>{c.headline}</p>
            <a class="text-link" href={`/campaigns/${c.slug}/`}>Read more &rarr;</a>
          </div>
        </article>
      ))}
    </div>
  </section>
  <DonateBand />
</Base>
