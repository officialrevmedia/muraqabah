---
import Base from '../../layouts/Base.astro';
import PageHero from '../../components/PageHero.astro';
import DonateBand from '../../components/DonateBand.astro';

const timeline = [
  { when: 'Enrolling Now', title: 'Chains of Trust: Foundations of Hadith Sciences', teacher: 'Shaykh Nuh Sanders', body: 'A live weekly online study of Al-Bayquniyyah, line by line. Sundays, 2:00 to 3:00 PM Eastern Time.', href: '/programs/chains-of-trust/', cta: 'Course details' },
  { when: 'Coming Soon', title: 'Gardens of Paradise: Weight of Words', teacher: 'Shaykh Zakaria Abdilaziz', body: 'A forthcoming weekly study circle opening with a series on the responsibility of speech.', href: '/programs/gardens-of-paradise/', cta: 'Register interest' },
  { when: '2027', title: 'Turkey Rihla', teacher: 'Muraqabah Initiative', body: 'A guided journey to Istanbul bringing together structured learning, suhbah, exploration, and companionship.', href: '/rihla-2027/', cta: 'Explore the Rihla' },
  { when: 'Eid al-Adha 2026', title: 'Qurbani 2026: Yemen', teacher: 'Completed campaign', body: 'More than $20,000 raised and roughly 100 animals facilitated, reaching over 300 households across Tarim, Yemen.', href: '/campaigns/qurbani-2026/', cta: 'See the distribution' },
  { when: 'Ramadan 2026', title: 'Feed 1,000+ People This Ramadan', teacher: 'Completed campaign', body: '$14,725.80 raised in two weeks: 380 family packages, 648 hot meals, and $3,850 in direct assistance.', href: '/campaigns/ramadan-2026/', cta: 'Read the report' },
  { when: 'Completed', title: 'Spheres of Faith: Islam, Iman, Ihsan, and Irfan', teacher: 'Shaykh Zakaria Abdilaziz', body: 'Our first flagship weekly program, taught live from Tarim, with more than 80 students attending each week for months.', href: '/programs/spheres-of-faith/', cta: 'Explore the archive' },
  { when: '2025', title: 'Sacred Nights', teacher: 'Shaykh Zakaria Abdilaziz', body: 'A special Ramadan program on the rank of the last ten nights, with a clear strategy for seeking Laylat al-Qadr.' },
  { when: '2025 \u00B7 Sold out', title: 'The Perfect Example', teacher: 'Shaykh Zakaria Abdilaziz', body: 'A dedicated course on the life and character of the Prophet \uFDFA, hosted at Sheridan College.' },
  { when: '2025 \u00B7 Sold out', title: 'The Beginning of Guidance', teacher: 'Shaykh Zakaria Abdilaziz', body: 'Muraqabah\u2019s debut one-day intensive on Imam al-Ghazali\u2019s classic, with more than 100 people in attendance.' }
];
---
<Base
  title="Events and History | Muraqabah Initiative"
  description="A timeline of Muraqabah Initiative programs, courses, intensives, and khidmah campaigns, from our debut intensive through the upcoming Turkey Rihla 2027."
>
  <PageHero
    eyebrow="Events & History"
    title="What we have built, and what is next"
    lede="From our debut intensive to the upcoming Turkey Rihla, a record of the programs and campaigns that make up Muraqabah's story."
    crumbs={[{ name: 'Home', href: '/' }, { name: 'Events & Rihla', href: '/events/' }]}
  />
  <section class="section--tight" style="padding-bottom: clamp(4rem, 8vw, 6rem);">
    <div class="container container--mid">
      <ol class="timeline">
        {timeline.map((item) => (
          <li data-reveal>
            <p class="when">{item.when}</p>
            <h3>{item.title}</h3>
            <p class="meta" style="font-size: 0.85rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: var(--ink-soft);">{item.teacher}</p>
            <p>{item.body}</p>
            {item.href && <a class="text-link" href={item.href}>{item.cta} &rarr;</a>}
          </li>
        ))}
      </ol>
    </div>
  </section>
  <DonateBand />
</Base>
