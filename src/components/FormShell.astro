---
/**
 * Accessible form wrapper for a static-site form service (Formspree or
 * compatible). If the endpoint has not been configured in
 * src/config/site.ts, a graceful email fallback is shown instead so the
 * site never claims an unconfigured form is operational.
 */
import { site } from '../config/site';
interface Props {
  endpoint: string;
  name: string;               // used for the fallback email subject
  submitLabel?: string;
  eventName?: string;         // optional analytics event
}
const { endpoint, name, submitLabel = 'Send', eventName } = Astro.props;
const subject = encodeURIComponent(`${name} - ${site.name}`);
---

{endpoint ? (
  <form class="form" method="POST" action={endpoint} data-form novalidate>
    <slot />
    <p class="hp-field" aria-hidden="true">
      <label>Leave this field empty <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" /></label>
    </p>
    <label class="check">
      <input type="checkbox" name="consent" required />
      <span>I consent to {site.name} contacting me about this request and storing my submission. <span class="req" aria-hidden="true">*</span></span>
    </label>
    <p class="form-note">
      Required fields are marked with an asterisk. Read our <a href="/privacy/">privacy policy</a> to learn how your
      information is handled. Submissions are delivered to {site.email}.
    </p>
    <div class="form-status" role="status" aria-live="polite" data-status></div>
    <div class="btn-row">
      <button class="btn btn-primary" type="submit" data-event={eventName}>{submitLabel}</button>
    </div>
  </form>
) : (
  <div class="form-fallback">
    <p><strong>This form is almost ready.</strong> While we finish setting it up, please email us directly and we will respond as soon as we can.</p>
    <a class="btn btn-primary" href={`mailto:${site.email}?subject=${subject}`}>Email {site.email}</a>
  </div>
)}

<script>
  document.querySelectorAll<HTMLFormElement>('form[data-form]').forEach((form) => {
    const status = form.querySelector<HTMLElement>('[data-status]');
    const setFieldState = (input: HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement) => {
      const field = input.closest('.field, .check');
      field?.classList.toggle('is-error', !input.checkValidity());
    };
    form.querySelectorAll<HTMLInputElement>('input, textarea, select').forEach((input) => {
      input.addEventListener('blur', () => setFieldState(input));
      input.addEventListener('input', () => { if (input.closest('.is-error')) setFieldState(input); });
    });
    form.addEventListener('submit', async (e) => {
      if (!form.checkValidity()) {
        e.preventDefault();
        form.querySelectorAll<HTMLInputElement>('input, textarea, select').forEach(setFieldState);
        const firstInvalid = form.querySelector<HTMLElement>(':invalid');
        firstInvalid?.focus();
        if (status) { status.className = 'form-status is-fail'; status.textContent = 'Please complete the highlighted fields before sending.'; }
        return;
      }
      e.preventDefault();
      const btn = form.querySelector<HTMLButtonElement>('button[type="submit"]');
      if (btn) { btn.disabled = true; btn.textContent = 'Sending\u2026'; }
      try {
        const res = await fetch(form.action, {
          method: 'POST',
          body: new FormData(form),
          headers: { Accept: 'application/json' }
        });
        if (!res.ok) throw new Error('Request failed');
        form.reset();
        if (status) { status.className = 'form-status is-ok'; status.textContent = 'Thank you. Your submission has been received and we will be in touch soon.'; }
      } catch {
        if (status) { status.className = 'form-status is-fail'; status.textContent = 'Something went wrong sending your submission. Please try again, or email us directly at info@muraqabah.ca.'; }
      } finally {
        if (btn) { btn.disabled = false; btn.textContent = btn.dataset.label || 'Send'; }
      }
    });
    const btn = form.querySelector<HTMLButtonElement>('button[type="submit"]');
    if (btn) btn.dataset.label = btn.textContent || 'Send';
  });
</script>
