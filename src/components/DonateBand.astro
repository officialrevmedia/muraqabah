---
import { links } from '../config/site';
---
<section class="section section--dark">
  <div class="container split">
    <div data-reveal>
      <p class="eyebrow">Support the Mission</p>
      <h2>Preserve Knowledge. Transform Hearts.</h2>
      <p class="muted" style="max-width: 36rem;">
        Your support sustains the transmission of sacred knowledge, compensates our teachers fairly, produces
        accessible educational resources, expands community service, and grows Muraqabah's reach across Canada
        and beyond. Every contribution becomes part of a continuing chain of benefit.
      </p>
      <div class="btn-row">
        <a class="btn btn-cream" href={links.donate} rel="noopener" data-event="Donate Click">Give Once or Monthly</a>
        <a class="btn btn-outline-cream" href="/donate/">Why Support Muraqabah</a>
      </div>
      <p class="muted" style="font-size: 0.84rem; margin-top: 1.1rem;">Donations are processed on a secure Zeffy page.</p>
    </div>
    <div class="arch" data-reveal>
      <img src="/images/photos/khidmah-rice-tarim.webp" alt="Rice support being delivered to a household in Tarim, Yemen" width="700" height="933" loading="lazy" style="aspect-ratio: 4/5;" />
    </div>
  </div>
</section>
