---
import Breadcrumbs from './Breadcrumbs.astro';
interface Props {
  eyebrow: string;
  title: string;
  lede?: string;
  crumbs?: { name: string; href: string }[];
}
const { eyebrow, title, lede, crumbs } = Astro.props;
---
<div class="page-hero">
  <div class="container">
    {crumbs && <Breadcrumbs items={crumbs} />}
    <p class="eyebrow">{eyebrow}</p>
    <h1>{title}</h1>
    {lede && <p class="lede">{lede}</p>}
    <slot />
  </div>
</div>
