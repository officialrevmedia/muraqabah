---
import { breadcrumbSchema } from '../lib/schema';
interface Props { items: { name: string; href: string }[] }
const { items } = Astro.props;
---
<nav class="crumbs" aria-label="Breadcrumb">
  <ol>
    {items.map((item, i) => (
      <li>
        {i < items.length - 1 ? <a href={item.href}>{item.name}</a> : <span aria-current="page">{item.name}</span>}
      </li>
    ))}
  </ol>
</nav>
<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema(items))} />
